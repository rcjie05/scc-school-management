<script>
function toggleBracket(el) {
  el.textContent = el.textContent.trim() === '✓' ? '' : '✓';
}
function buildRows(tbodyId, totalId) {
  const tbody = document.getElementById(tbodyId);
  for (let i = 0; i < 8; i++) {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><input class="ci" type="text"></td>
      <td><input class="ci" type="text" style="width:100%;"></td>
      <td><input class="ci ci-center" type="number" min="0" step="0.5" oninput="calcTotal('${tbodyId}','${totalId}')"></td>
      <td><input class="ci ci-center" type="number" min="0" step="0.5" oninput="calcTotal('${tbodyId}','${totalId}')"></td>
      <td><input class="ci ci-center" type="text"></td>
      <td><input class="ci ci-center" type="text"></td>
      <td><input class="ci ci-center" type="text"></td>
      <td><input class="ci" type="text"></td>
    `;
    tbody.appendChild(tr);
  }
}
function calcTotal(tbodyId, totalId) {
  let t = 0;
  document.querySelectorAll(`#${tbodyId} input[type=number]`).forEach(i => { t += parseFloat(i.value) || 0; });
  document.getElementById(totalId).textContent = t > 0 ? t : '';
}

buildRows('tbody-s', 'total-s');
buildRows('tbody-r', 'total-r');
</script>
</body>

<script>
(async function applyBranding() {
    try {
        const res  = await fetch('php/api/get_branding_public.php');
        const data = await res.json();
        if (!data.success) return;
        const name = data.school_name || '';
        if (name) {
            document.querySelectorAll('.sc-name').forEach(el => el.textContent = name);
            const hdr = document.getElementById('brandNameHeader');
            if (hdr) hdr.textContent = name;
            document.title = 'Enrollment Form — ' + name;
        }
    } catch(e) {}
})();
</script>
</html>